{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://docs.remembra.dev",
      "permanent": true
    },
    {
      "source": "/docs/:path*",
      "destination": "https://docs.remembra.dev/:path*",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/changelog",
      "permanent": false
    },
    {
      "source": "/blog/:slug",
      "destination": "/changelog/:slug",
      "permanent": false
    }
  ]
}
